PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
HUGGINGFACE_API_KEY=hf_your_token_here
MUSIC_MODEL_ID=facebook/musicgen-small
SONGGEN_SPACE_ID=tencent/SongGeneration
# Optional: use a dedicated Hugging Face Inference Endpoint instead of the shared router.
# HF_ENDPOINT_URL=https://your-endpoint.endpoints.huggingface.cloud

# Google AI API key for Lyria music generation
GOOGLE_API_KEY=your_google_api_key_here
# Lyria model to use (options: lyria-3-clip-preview, lyria-3-pro-preview)
LYRIA_MODEL_ID=lyria-3-pro-preview
